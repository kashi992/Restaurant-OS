# ============================================================================
# RESTAURANT POS + QR ORDERING SAAS - ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
# Full connection string (recommended)
DATABASE_URL=postgresql://username:password@localhost:5432/restaurant_pos

# Or individual connection parameters
PGHOST=localhost
PGPORT=5432
PGUSER=your_username
PGPASSWORD=your_password
PGDATABASE=restaurant_pos

# ============================================================================
# SERVER
# ============================================================================
PORT=5000
NODE_ENV=development

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================================================
# SESSION (Express Session)
# ============================================================================
# Generate a strong secret: openssl rand -hex 32
SESSION_SECRET=your-session-secret-change-this-in-production

# ============================================================================
# CORS (if frontend is on different domain)
# ============================================================================
CORS_ORIGIN=http://localhost:5000

# ============================================================================
# OPTIONAL: REDIS (for session store in production)
# ============================================================================
# REDIS_URL=redis://localhost:6379

# ============================================================================
# OPTIONAL: FILE UPLOADS (for menu images, logos)
# ============================================================================
# UPLOAD_DIR=./uploads
# MAX_FILE_SIZE=5242880

# ============================================================================
# OPTIONAL: EMAIL (for notifications, password reset)
# ============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# EMAIL_FROM=noreply@yourrestaurant.com

# ============================================================================
# OPTIONAL: PAYMENT GATEWAYS
# ============================================================================
# Stripe (for card payments)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# PayPal (for PayPal payments)
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_CLIENT_SECRET=your_paypal_client_secret
# PAYPAL_MODE=live  # or 'sandbox' for testing
